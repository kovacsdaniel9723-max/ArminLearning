{
  "expo": {
    "name": "Armin Learning",
    "slug": "armin-learning-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "experiments": {
      "baseUrl": "/ArminLearning"
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4A90E2"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.armin.learningapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A90E2"
      },
      "package": "com.armin.learningapp",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow Armin Learning App to access your microphone for voice games."
        }
      ],
      "expo-asset",
      "expo-audio",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "ed36f6fe-db63-4d44-a0b9-2878be12a2f0"
      }
    }
  }
}
